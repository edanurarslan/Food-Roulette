# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/food_roulette_db
POSTGRES_USER=food_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=food_roulette_db

# FastAPI
ENVIRONMENT=development
DEBUG=true
API_V1_STR=/api/v1

# JWT
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
